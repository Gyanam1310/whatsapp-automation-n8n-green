# ─────────────────────────────────────────────────────────────────────────────
# Gaurakshan WhatsApp Automation — Environment Configuration
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Comma-separated allowed CORS origins
CORS_ORIGIN=http://localhost,http://localhost:3000

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Spreadsheet ID from the URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_TAB_NAME=Sheet1

# ── Google Drive ──────────────────────────────────────────────────────────────
# Root folder ID from the URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here

# ── Google Service Account ────────────────────────────────────────────────────
# Place your downloaded service account JSON at: backend/service-account.json
# Do NOT commit that file — it is excluded by .gitignore.

# ── GreenAPI (WhatsApp) ───────────────────────────────────────────────────────
# Get from: https://app.green-api.com/
GREENAPI_INSTANCE_ID=your_instance_id_here
GREENAPI_API_TOKEN=your_api_token_here
GREENAPI_URL=https://api.green-api.com

# WhatsApp group ID (format: 1234567890-1234567890@g.us)
WHATSAPP_GROUP_ID=your_whatsapp_group_id_here

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http

# Webhook URL n8n uses for triggers (internal Docker network)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/whatsapp-trigger

# ── Scheduling ────────────────────────────────────────────────────────────────
# Cron expression for daily automation (default: 8:00 AM)
DAILY_CRON_EXPRESSION=0 8 * * *
