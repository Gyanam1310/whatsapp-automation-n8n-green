# Backend environment — for local development without Docker.
# In Docker, variables are injected via docker-compose.yml from the root .env.
# Copy to backend/.env and fill in values.

NODE_ENV=development
PORT=5000

CORS_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:5000

GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_TAB_NAME=Sheet1
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here

GREENAPI_URL=https://api.green-api.com
GREENAPI_INSTANCE_ID=your_instance_id_here
GREENAPI_API_TOKEN=your_api_token_here
GREENAPI_WEBHOOK_URL=http://localhost:5000/api/webhooks/whatsapp

WHATSAPP_GROUP_ID=your_whatsapp_group_id_here

N8N_WEBHOOK_URL=http://localhost:5678/webhook/whatsapp-trigger

DAILY_CRON_EXPRESSION=0 7 * * *
